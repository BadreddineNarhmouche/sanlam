<log4net>
	<appender name="LogToRollingFile" type="log4net.Appender.RollingFileAppender">
		<file value="Logs/SACheckTrackingPlatformServicesPartnersExternalService.log" />
		<appendToFile value="true" />
		<rollingStyle value="Date" />
		<datePattern value="ddMMyyyy" />
		<maxSizeRollBackups value="31" />
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="[%level] [%thread] [%date{dd'/'MM'/'yyyy HH':'mm':'ss}] [%message]%newline" />
		</layout>
	</appender>
	<root>
		<level value="ALL" />
		<appender-ref ref="LogToRollingFile" />
	</root>
</log4net>