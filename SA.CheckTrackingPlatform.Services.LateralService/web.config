<?xml version="1.0" encoding="utf-8"?>
<!--SA.CheckTrackingPlatform.Services.LateralService-->
<configuration>
	<system.web>
		<customErrors mode="Off" />
		<authorization>
			<allow verbs="HEAD" users="*" />
			<allow verbs="GET" users="*" />
			<allow verbs="POST" users="*" />
			<allow verbs="PUT" users="*" />
			<allow verbs="DELETE" users="*" />
			<allow verbs="OPTIONS" users="*" />
		</authorization>
		<httpHandlers>
			<remove verb="PROPFIND" path="*" />
			<remove verb="COPY" path="*" />
			<remove verb="LOCK" path="*" />
			<remove verb="UNLOCK" path="*" />
			<remove verb="PROPPATCH" path="*" />
			<remove verb="MKCOL" path="*" />
			<remove verb="MOVE" path="*" />
		</httpHandlers>
	</system.web>
	<system.webServer>
		<serverSideInclude ssiExecDisable="false" />
		<validation validateIntegratedModeConfiguration="false" />
		<modules runAllManagedModulesForAllRequests="true" />
		<caching enabled="false" enableKernelCache="false" />
		<urlCompression doStaticCompression="false" doDynamicCompression="false" dynamicCompressionBeforeCache="false" />
		<directoryBrowse enabled="false" showFlags="None" />
		<httpProtocol>
			<customHeaders>
				<clear />
				<remove name="Server" />
				<remove name="X-AspNet-Version" />
				<remove name="X-AspNetMvc-Version" />
				<remove name="X-Powered-By" />
				<add name="Cache-Control" value="no-cache, no-store, max-age=0, must-revalidate" />
				<add name="Pragma" value="no-cache" />
				<add name="Expires" value="0" />
				<add name="X-Content-Type-Options" value="nosniff" />
				<add name="X-Frame-Options" value="DENY" />
				<add name="X-XSS-Protection" value="1; mode=block" />
			</customHeaders>
		</httpProtocol>
		<security>
			<requestFiltering>
				<verbs>
					<add verb="TRACE" allowed="false" />
					<add verb="CONNECT" allowed="false" />
					<add verb="PROPFIND" allowed="false" />
					<add verb="PROPPATCH" allowed="false" />
					<add verb="MKCOL" allowed="false" />
					<add verb="COPY" allowed="false" />
					<add verb="MOVE" allowed="false" />
					<add verb="LOCK" allowed="false" />
					<add verb="UNLOCK" allowed="false" />
					<add verb="VERSION-CONTROL" allowed="false" />
					<add verb="REPORT" allowed="false" />
					<add verb="CHECKOUT" allowed="false" />
					<add verb="CHECKIN" allowed="false" />
					<add verb="UNCHECKOUT" allowed="false" />
					<add verb="MKWORKSPACE" allowed="false" />
					<add verb="UPDATE" allowed="false" />
					<add verb="LABEL" allowed="false" />
					<add verb="MERGE" allowed="false" />
					<add verb="BASELINE-CONTROL" allowed="false" />
					<add verb="MKACTIVITY" allowed="false" />
					<add verb="ORDERPATCH" allowed="false" />
					<add verb="ACL" allowed="false" />
					<add verb="PATCH" allowed="false" />
					<add verb="SEARCH" allowed="false" />
					<add verb="BCOPY" allowed="false" />
					<add verb="BDELETE" allowed="false" />
					<add verb="BMOVE" allowed="false" />
					<add verb="BPROPFIND" allowed="false" />
					<add verb="BPROPPATCH" allowed="false" />
					<add verb="NOTIFY" allowed="false" />
					<add verb="POLL" allowed="false" />
					<add verb="SUBSCRIBE" allowed="false" />
					<add verb="UNSUBSCRIBE" allowed="false" />
					<add verb="X-MS-ENUMATTS" allowed="false" />
				</verbs>
			</requestFiltering>
		</security>
		<rewrite>
			<outboundRules rewriteBeforeCache="true">
				<rule name="Remove Server Header" stopProcessing="true">
					<match serverVariable="RESPONSE_SERVER" pattern=".+" />
					<action type="Rewrite" value="Server" />
				</rule>
			</outboundRules>
		</rewrite>
	</system.webServer>
</configuration>